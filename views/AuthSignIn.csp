<!DOCTYPE html>
<html lang="en" data-theme="silk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In - Ak ACL</title>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.14/dist/full.min.css" rel="stylesheet" type="text/css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    [data-theme="silk"] {
      color-scheme: light;
      --rounded-box: 1rem; --rounded-btn: 0.5rem; --rounded-badge: 2rem;
      --animation-btn: 0.25s; --animation-input: 0.2s; --btn-focus-scale: 0.95;
      --border-btn: 2px; --tab-border: 2px; --tab-radius: 0.5rem;
      --b1: 97% 0.0035 67.78; --b2: 95% 0.0081 61.42; --b3: 90% 0.0081 61.42; --bc: 40% 0.0081 61.42;
      --p: 23.27% 0.0249 284.3; --pc: 94.22% 0.2505 117.44;
      --s: 23.27% 0.0249 284.3; --sc: 73.92% 0.2135 50.94;
      --a: 23.27% 0.0249 284.3; --ac: 88.92% 0.2061 189.9;
      --n: 20% 0 0; --nc: 80% 0.0081 61.42;
      --in: 80.39% 0.1148 241.68; --inc: 30.39% 0.1148 241.68;
      --su: 83.92% 0.0901 136.87; --suc: 23.92% 0.0901 136.87;
      --wa: 83.92% 0.1085 80; --wac: 43.92% 0.1085 80;
      --er: 75.1% 0.1814 22.37; --erc: 35.1% 0.1814 22.37;
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-3xl font-bold text-center justify-center mb-2">Ak ACL 🩴</h2>
      <p class="text-center text-base-content/70 mb-6">Sign in to your account to continue</p>

      <%c++ auto message = @@.get<std::string>("message"); %>
      <%c++ if (!message.empty()) { %>
      <div class="alert alert-error">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span><%c++ $$<<message; %></span>
      </div>
      <%c++ } %>

      <form method="POST" action="/ak-acl/auth/signin?to=/ak-acl/management/employee/control" class="space-y-4">
        <div class="form-control">
          <input
            type="text"
            id="username"
            name="username"
            placeholder="Enter your username"
            class="input input-bordered w-full"
            required
            autocomplete="username"
            autofocus
          />
        </div>

        <div class="form-control">
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Enter your password"
            class="input input-bordered w-full"
            required
            autocomplete="current-password"
          />
        </div>

        <div class="form-control">
          <button type="submit" class="btn btn-primary w-full">Sign In</button>
        </div>
      </form>

      <div class="divider text-xs text-base-content/50">OR</div>

      <div class="text-center text-sm">
        <span class="text-base-content/70">Don't have an account?</span>
        <a href="/auth/register" class="link link-primary font-medium ml-1">Sign up</a>
      </div>
    </div>
  </div>
</body>
</html>
